# ─── Copy this file to .env and fill in your values ──────────────────────────
# Never commit the actual .env file

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telemedicine_db
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password_here

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=telemedicine_logs
MONGO_USERNAME=mongo
MONGO_PASSWORD=your_mongo_password_here

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here_must_be_at_least_32_characters_long
JWT_EXPIRATION_MS=86400000

# ─── Spring Boot ──────────────────────────────────────────────────────────────
SPRING_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ─── AI Microservices ─────────────────────────────────────────────────────────
SYMPTOM_SERVICE_URL=http://localhost:8001
IMAGE_SERVICE_URL=http://localhost:8002

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api
